# Application Settings
FLASK_ENV=development
API_PORT=5000
DEBUG=True

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB_NAME=arca_db

# AWS Configuration (Optional)
AWS_REGION=us-east-1
AWS_S3_BUCKET=arca-logs-storage

# Security
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# Clerk Authentication (optional — omit to disable auth in dev)
# Get from: Clerk Dashboard → API Keys → Advanced → JWKS URL
# Format: https://<your-clerk-frontend-api>/.well-known/jwks.json
CLERK_JWKS_URL=

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Monitoring
ENABLE_METRICS=True
LOG_LEVEL=INFO

# Anomaly Detection Thresholds
CPU_THRESHOLD=80
MEMORY_THRESHOLD=85
RESPONSE_TIME_THRESHOLD=2000
ERROR_RATE_THRESHOLD=5
